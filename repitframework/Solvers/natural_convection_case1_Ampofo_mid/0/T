FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 303.15;

boundaryField
{


    topAndBottom
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            zeroGradient;
    }

    hot
    {
        type            fixedValue;
        value           uniform 323.15; // 34.6 degC
    }

    cold
    {
        type            fixedValue;
        value           uniform 283.15; // 15 degC
    }
}


